# Path to Obsidian vault (REQUIRED)
# Windows: C:\Users\you\Documents\Obsidian\MyVault
# Mac:     ~/Documents/Obsidian/MyVault
OBSIDIAN_VAULT=

# Path to ChromaDB storage (auto-created)
CHROMA_DB_PATH=./data/chromadb

# Ollama embedding model
EMBED_MODEL=nomic-embed-text

# Ollama base URL
OLLAMA_BASE_URL=http://localhost:11434

# Watcher debounce delay (milliseconds)
WATCH_DEBOUNCE_MS=500

# Indexing chunk size (characters)
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# Number of chunks returned by search
TOP_K_RESULTS=5

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
